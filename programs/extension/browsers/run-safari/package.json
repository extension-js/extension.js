{
  "name": "rspack-run-safari-extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Safari builder for Extension.js, converts the built web extension into a Safari app via xcrun/xcodebuild. macOS only.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/extension-js/extension.js.git",
    "directory": "programs/extension/browsers/run-safari"
  },
  "x-internal-path": "programs/extension/browsers/run-safari",
  "x-exports": {
    "function": "packageSafariExtension",
    "entry": "./safari-launch/index.ts"
  }
}
