{
  "$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
  "files": {
    "ignoreUnknown": true,
    "maxSize": 262144,
    "includes": [
      "**",
      "!_FUTURE",
      "!extensions",
      "!extensions/**/dist",
      "!templates/**/dist",
      "!templates-artifacts",
      "!**/dist",
      "!**/.rslib",
      "!**/build",
      "!**/out",
      "!**/coverage",
      "!**/e2e-report",
      "!**/playwright-report",
      "!**/.next",
      "!**/.nuxt",
      "!**/.svelte-kit",
      "!**/.vite",
      "!**/.cache",
      "!**/.turbo",
      "!**/.pnpm-store",
      "!extensions/browser-extension",
      "!extensions/monorepo",
      "!**/__TEST__",
      "!**/webpack.config.js",
      "!**/postcss.config.js",
      "!**/tailwind.config.js",
      "!**/stylelint.config.json",
      "!**/.tmp-*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "none",
      "bracketSpacing": false,
      "semicolons": "asNeeded",
      "arrowParentheses": "always"
    }
  },
  "overrides": [
    {
      "includes": [
        "programs/**",
        "!programs/develop/plugin-reload/steps/setup-reload-strategy/webpack-target-webextension-fork/**",
        "!**/__spec__/**",
        "!**/*.spec.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "error"
          }
        }
      }
    }
  ],
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noPrototypeBuiltins": "off",
        "noControlCharactersInRegex": "off",
        "useIterableCallbackReturn": "error",
        "noAssignInExpressions": "off",
        "noAsyncPromiseExecutor": "error",
        "noImplicitAnyLet": "error"
      },
      "a11y": {
        "recommended": false
      }
    }
  }
}
