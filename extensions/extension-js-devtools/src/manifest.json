{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "manifest_version": 3,
  "version": "3.0.0",
  "name": "Extension.js",
  "description": "Extension.js built-in developer tools",
  "chromium:manifest_version": 3,
  "firefox:manifest_version": 2,
  "chromium:key": "",
  "firefox:browser_specific_settings": {
    "gecko": {
      "id": "devtools@extension.js"
    }
  },
  "author": "Cezar Augusto",
  "icons": {
    "48": "images/logo.png"
  },
  "chromium:action": {
    "default_icon": {
      "48": "images/logo.png"
    },
    "default_title": "Open Extension.js"
  },
  "firefox:browser_action": {
    "default_icon": {
      "48": "images/logo.png"
    },
    "default_title": "Open Extension.js"
  },
  "devtools_page": "devtools/index.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/scripts.tsx"],
      "run_at": "document_idle"
    }
  ],
  "chromium:permissions": ["management", "tabs", "storage", "webNavigation"],
  "firefox:permissions": ["management", "tabs", "storage"],
  "chromium:host_permissions": ["<all_urls>"],
  "background": {
    "chromium:service_worker": "background/index.ts",
    "firefox:scripts": ["background/index.ts"]
  },
  "chromium:chrome_url_overrides": {
    "newtab": "pages/newtab.html"
  },
  "chromium:web_accessible_resources": [
    {
      "resources": ["assets/*", "scripts/*", "pages/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
