{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["EXTENSION_AUTHOR_MODE", "npm_config_user_agent"],
  "tasks": {
    "compile": {
      "outputs": ["dist/**"],
      "dependsOn": ["^compile"]
    },
    "watch": {
      "cache": false,
      "persistent": true,
      "outputs": ["dist/**"],
      "dependsOn": ["^compile"]
    },
    "test": {
      "dependsOn": ["^compile"]
    },

    "test:build": {},
    "test:cli": {},
    "test:dev": {},
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
