EXTENSION_AUTHOR_MODE=
EXTENSION_DLX=
EXTENSION_EXPERIMENTAL_ERRORS_PLUGIN=
EXTENSION_EXPERIMENTAL_RESOLVER_PLUGIN=
NPM_TOKEN=

# --- Telemetry -------------------------------------------------------------
# CLI write-side (public project key — safe to commit/publish)
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Optional overrides (defaults are sane for the free tier)
# EXTENSION_TELEMETRY=0                   # disable entirely (hardest override)
# EXTENSION_TELEMETRY_SAMPLE_RATE=0.2     # 0.0–1.0, applies to command_executed only
# EXTENSION_TELEMETRY_MAX_EVENTS=3        # per-run cap
# EXTENSION_TELEMETRY_DEBOUNCE_MS=60000   # dedup window per (event,command,success)
# EXTENSION_TELEMETRY_DEBUG=1             # print payloads to stderr

# Query-side (personal API key — used by PostHog MCP / usage scripts only,
# never by the CLI at runtime). Create at https://us.posthog.com/settings/user-api-keys
POSTHOG_API_ENDPOINT=https://us.posthog.com
POSTHOG_PERSONAL_API_KEY=
